{
  "name": "hyperion-explorer",
  "version": "1.4.1",
  "description": "Official Lightweight Explorer for Hyperion History APIs",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4210",
    "start:ssl": "ng serve --host 0.0.0.0 --ssl",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "watch:prod": "ng build --watch --configuration production",
    "test": "ng test",
    "serve:ssr:hyperion-explorer": "node dist/hyperion-explorer/server/server.mjs",
    "serve:ssr:watch": "node --watch dist/hyperion-explorer/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/ssr": "^21.2.3",
    "@eosrio/hyperion-stream-client": "4.0.0-rc.3",
    "@fastify/compress": "^8.1.0",
    "@fastify/static": "^8.2.0",
    "@fortawesome/angular-fontawesome": "^3.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.0.1",
    "@fortawesome/free-brands-svg-icons": "^7.0.1",
    "@fortawesome/free-regular-svg-icons": "^7.0.1",
    "@fortawesome/free-solid-svg-icons": "^7.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tweenjs/tween.js": "^25.0.0",
    "echarts": "^6.0.0",
    "fastify": "^5.4.0",
    "motion": "^12.38.0",
    "ngx-echarts": "^21.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@types/jasmine": "^5.1.9",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.21",
    "jasmine-core": "~5.10.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.8",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
